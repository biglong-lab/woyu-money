# ============================================================
# 本地開發環境變數範本（複製成 .env、填入真實值）
# ============================================================

# DB（本地 Docker postgres、port 5439）
DATABASE_URL=postgresql://woyu:woyu123@localhost:5439/woyu_money

# Session secret — 至少 32 字元隨機字串
# 產生：openssl rand -hex 32
SESSION_SECRET=change-me-to-32-chars-random-hex

NODE_ENV=development
PORT=5001

# ============================================================
# 選配整合
# ============================================================

# AI 辨識（Gemini）
GEMINI_API_KEY=your-gemini-api-key

# LINE 登入 / Bot
# LINE_CHANNEL_ID=
# LINE_CHANNEL_SECRET=
# LINE_CALLBACK_URL=http://localhost:5001/api/auth/line/callback
# LINE_BOT_CHANNEL_ACCESS_TOKEN=
# LINE_BOT_CHANNEL_SECRET=

# Web Push（VAPID）— 產生：npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@homi.cc

# PM / PMS Bridge — 唯讀同步源（生產用）
# PM_DATABASE_URL=postgresql://...
# PMS_DATABASE_URL=postgresql://...

# ============================================================
# 生產（docker-compose 部署用）
# ============================================================
# POSTGRES_PASSWORD — 必填、用於 Postgres container 啟動 + app DATABASE_URL
# 產生：openssl rand -hex 24
# POSTGRES_PASSWORD=
